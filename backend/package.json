{
  "name": "turnero-backend",
  "version": "1.0.0",
  "description": "API REST para sistema de turnos de barberías",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "setup:admin": "tsx scripts/setup-admin-db.ts",
    "seed:super": "tsx scripts/seed-super-admin.ts",
    "seed:tenants": "tsx scripts/seed-dev-tenants.ts",
    "seed:refresh-demo": "tsx scripts/seed-refresh-demo.ts",
    "migrate:idempotency": "tsx scripts/migrate-turnos-idempotency.ts",
    "migrate:notifications": "tsx scripts/migrate-notification-jobs.ts",
    "seed:plantillas": "tsx scripts/seed-plantillas-existing.ts",
    "migrate:onboarding": "tsx scripts/migrate-onboarding.ts",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:plan": "tsx scripts/migrate.ts plan",
    "migrate:apply": "tsx scripts/migrate.ts apply",
    "worker:notifications": "tsx src/workers/notificationWorker.ts",
    "scheduler": "tsx src/jobs/scheduler.ts",
    "setup:db": "npm run setup:admin && npm run seed:super && npm run seed:tenants",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:http": "jest tests/http --runInBand"
  },
  "keywords": [
    "barberia",
    "turnos",
    "api",
    "rest"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.10",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
