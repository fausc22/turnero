NODE_ENV=production
PORT=4013

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tuturno
DB_PASSWORD=CAMBIAR
DB_ADMIN_NAME=tuturno_admin
DB_TENANT_POOL_LIMIT=10
# Solo si LEGACY_API_ENABLED=true
DB_LEGACY_NAME=turnero

# Secretos >= 32 chars aleatorios (sin placeholders)
JWT_SECRET=generar-string-aleatorio-min-32-chars
JWT_REFRESH_SECRET=generar-otro-string-aleatorio-min-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d

SUPER_JWT_SECRET=generar-super-jwt-min-32-chars
SUPER_JWT_REFRESH_SECRET=generar-super-refresh-min-32
SUPER_JWT_EXPIRES_IN=8h
SUPER_JWT_REFRESH_EXPIRES_IN=7d

RESERVATION_TOKEN_SECRET=generar-reservation-token-secret

# Dominio prod (sin https)
BASE_DOMAIN=tudominio.com
CORS_ORIGINS=https://panel.tudominio.com,https://admin.tudominio.com
API_PUBLIC_URL=https://api.tudominio.com
CLIENT_BASE_HOST=tudominio.com
CLIENT_BASE_SCHEME=https

PUBLIC_RATE_LIMIT=60
AUTH_RATE_LIMIT=10
WEBHOOK_RATE_LIMIT=120
TRUST_PROXY_HOPS=1
BODY_LIMIT=1mb

# Guardrails producción
DEV_UNLIMITED=false
LEGACY_API_ENABLED=false
# Crons viven en tuturno-scheduler (Fase 5). No activar en API multi-instancia.
RUN_CRONS_IN_API=false
REQUIRE_RESERVATION_SIG=true

# Mercado Pago — obligatorio si hay pagos online
MP_WEBHOOK_SECRET=generar-mp-webhook-secret
# Opcional: cifrado de tokens MP en DB (AES-GCM key base64 32 bytes)
# MP_CREDENTIALS_KEY=
# Solo staging/tests — nunca en producción
# MP_TEST_ACCESS_TOKEN=

# Email
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=mailer
SMTP_PASS=CAMBIAR
SMTP_FROM=TuTurno <noreply@tudominio.com>

# Opcional
# OPENCAGE_API_KEY=

# Persistencia
UPLOADS_PATH=/srv/tuturno-data/uploads
BAILEYS_AUTH_PATH=/srv/tuturno-data/baileys
WORKER_ID=worker-1
SCHEDULER_LOCK_NAME=tuturno-scheduler
