# Ejemplo de variables para scripts de backup (copiar a ops/backup/.env — no versionar secretos)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tuturno_backup
DB_PASSWORD=CAMBIAR
DB_ADMIN_NAME=tuturno_admin
BACKUP_DIR=/srv/backups/tuturno
UPLOADS_PATH=/srv/tuturno-data/uploads
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_AGE_HOURS=26
